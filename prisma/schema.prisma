generator client {
  provider = "prisma-client"
  output   = "../lib/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

enum Locale {
  ko
  en
}

enum ContentType {
  QNA
  FAMILY_HEALTH_QNA
  HEALTH_GUIDE
  MONTHLY_GUIDE
  POLICY
  CHILDCARE_PORTAL_GUIDE
  FAMILY_FINANCE
  CHECKLIST
  INFO_PAGE
  BABY_NAME
  BABY_FOOD_RECIPE
  BABY_PRODUCT_QNA
  PLAY_ITEM
}

enum PublishStatus {
  DRAFT
  REVIEW
  PUBLISHED
  HIDDEN
}


enum AuthProvider {
  KAKAO
  GOOGLE
  APPLE
  PHONE
}

enum ChildGender {
  MALE
  FEMALE
  UNKNOWN
}

model ContentCategory {
  id          String      @id @default(cuid())
  locale      Locale      @default(ko)
  type        ContentType
  slug        String
  name        String
  shortName   String?
  description String?
  sortOrder   Int         @default(0)

  contents    Content[]

  createdAt   DateTime    @default(now())
  updatedAt   DateTime    @updatedAt

  @@unique([locale, type, slug])
  @@index([locale, type])
}

model Content {
  id              String        @id @default(cuid())

  locale          Locale        @default(ko)
  type            ContentType

  categoryId      String?
  category        ContentCategory? @relation(fields: [categoryId], references: [id])

  slug            String
  path            String        @unique

  title           String
  shortTitle      String?
  question        String?
  topic           String?
  summary         String

  ageMinMonth     Int?
  ageMaxMonth     Int?

  isMedical       Boolean       @default(false)
  isOfficialInfo  Boolean       @default(false)

  status          PublishStatus @default(DRAFT)
  reviewStatus    String        @default("NEEDS_REVIEW")
  duplicateMemo   String?
  editorMemo      String?

  metaTitle       String?
  metaDescription String?
  canonicalPath   String?
  ogTitle         String?
  ogDescription   String?

  publishedAt     DateTime?
  verifiedAt      DateTime?
  createdAt       DateTime      @default(now())
  updatedAt       DateTime      @updatedAt

  sections        ContentSection[]
  keywords        ContentKeyword[]
  sources         ContentSource[]

  outgoingLinks   ContentRelation[] @relation("ContentRelationFrom")
  incomingLinks   ContentRelation[] @relation("ContentRelationTo")

  @@unique([locale, type, slug])
  @@index([locale, type, status])
  @@index([categoryId])
  @@index([topic])
}

model ContentSection {
  id          String   @id @default(cuid())

  contentId   String
  content     Content  @relation(fields: [contentId], references: [id], onDelete: Cascade)

  sectionType String
  title       String?
  body        String?
  items       Json?
  sortOrder   Int      @default(0)

  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([contentId])
  @@index([contentId, sectionType])
}

model ContentKeyword {
  id        String  @id @default(cuid())

  contentId String
  content   Content @relation(fields: [contentId], references: [id], onDelete: Cascade)

  keyword   String

  @@unique([contentId, keyword])
  @@index([keyword])
}

model ContentSource {
  id          String   @id @default(cuid())

  contentId   String
  content     Content  @relation(fields: [contentId], references: [id], onDelete: Cascade)

  name        String
  url         String?
  description String?
  checkedAt   DateTime?

  @@index([contentId])
}

model ContentRelation {
  id            String  @id @default(cuid())

  fromContentId String
  fromContent   Content @relation("ContentRelationFrom", fields: [fromContentId], references: [id], onDelete: Cascade)

  toContentId   String
  toContent     Content @relation("ContentRelationTo", fields: [toContentId], references: [id], onDelete: Cascade)

  label         String
  description   String?
  reason        String?
  sortOrder     Int     @default(0)

  @@unique([fromContentId, toContentId])
  @@index([fromContentId])
  @@index([toContentId])
}
model ContentQualityBatch {
  id             String   @id @default(cuid())
  batchNo        Int      @unique
  label          String
  scope          String
  status         String   @default("READY")
  totalItems     Int      @default(0)
  completedItems Int      @default(0)
  startedAt      DateTime?
  completedAt    DateTime?
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  items          ContentQualityBatchItem[]

  @@index([status])
  @@index([scope])
}

model ContentQualityBatchItem {
  id           String   @id @default(cuid())
  batchId      String
  batch        ContentQualityBatch @relation(fields: [batchId], references: [id], onDelete: Cascade)

  batchNo      Int
  sequence     Int
  globalOrder  Int      @unique

  sourceKind   String
  sourceKey    String   @unique
  dbStatus     String   @default("DB_READY")
  contentId    String?

  path         String
  type         String
  category     String?
  title        String

  status       String   @default("READY")
  reviewStatus String?
  editorMemo   String?

  exportedAt   DateTime?
  completedAt  DateTime?
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  @@index([batchNo])
  @@index([status])
  @@index([dbStatus])
  @@index([type, category])
  @@index([sourceKind])
}

model CoupangProductCategory {
  id          String   @id @default(cuid())
  slug        String   @unique
  name        String
  description String?
  sortOrder   Int      @default(0)
  enabled     Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  links        CoupangProductLink[]
  pageMappings PageProductAdMapping[]

  @@index([enabled])
  @@index([sortOrder])
}

model CoupangProductLink {
  id          String   @id @default(cuid())
  categoryId  String
  slug        String
  title       String
  description String?
  partnerUrl  String
  imageUrl    String?
  buttonText  String   @default("상품 보러가기")
  sortOrder   Int      @default(0)
  enabled     Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  category    CoupangProductCategory @relation(fields: [categoryId], references: [id], onDelete: Cascade)

  @@unique([categoryId, slug])
  @@index([categoryId])
  @@index([enabled])
  @@index([sortOrder])
}

model PageProductAdMapping {
  id          String   @id @default(cuid())
  pagePath    String
  categoryId  String
  priority    Int      @default(0)
  enabled     Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  category    CoupangProductCategory @relation(fields: [categoryId], references: [id], onDelete: Cascade)

  @@unique([pagePath, categoryId])
  @@index([pagePath])
  @@index([enabled])
  @@index([priority])
}

model User {
  id          String    @id @default(cuid())
  email       String?
  nickname    String?

  lastLoginAt DateTime?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
  deletedAt   DateTime?

  accounts    UserAccount[]
  children    Child[]
  familyMemberships FamilyMember[]

  @@index([deletedAt])
  @@index([lastLoginAt])
}

model UserAccount {
  id                String       @id @default(cuid())
  userId            String
  provider          AuthProvider
  providerAccountId String

  email             String?
  profileImageUrl   String?

  createdAt         DateTime     @default(now())
  updatedAt         DateTime     @updatedAt

  user              User         @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
  @@index([userId])
}


model FamilyGroup {
  id          String   @id @default(cuid())
  name        String   @default("우리 가족")
  inviteCode  String   @unique
  inviteCodeUpdatedAt DateTime @default(now())

  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  members     FamilyMember[]
  children    Child[]

  @@index([inviteCode])
}

model FamilyMember {
  id            String   @id @default(cuid())
  familyGroupId String
  userId        String

  role          String   @default("CAREGIVER")
  status        String   @default("ACTIVE")
  joinedAt      DateTime @default(now())

  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  familyGroup   FamilyGroup @relation(fields: [familyGroupId], references: [id], onDelete: Cascade)
  user          User        @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([familyGroupId, userId])
  @@index([userId])
  @@index([familyGroupId])
  @@index([status])
}

model Child {
  id          String       @id @default(cuid())
  userId      String
  familyGroupId String?

  nickname    String?
  birthDate   DateTime     @db.Date
  expectedDueDate DateTime? @db.Date
  useCorrectedAge Boolean   @default(false)
  gender      ChildGender?
  isPrimary   Boolean      @default(false)

  createdAt   DateTime     @default(now())
  updatedAt   DateTime     @updatedAt
  deletedAt   DateTime?

  user        User         @relation(fields: [userId], references: [id], onDelete: Cascade)
  familyGroup FamilyGroup? @relation(fields: [familyGroupId], references: [id], onDelete: SetNull)
  developmentRecords ChildDevelopmentRecord[]
  developmentCheckLogs ChildDevelopmentCheckLog[]
  weaningRecords ChildWeaningRecord[]
  vaccinationRecords ChildVaccinationRecord[]

  @@index([userId])
  @@index([familyGroupId])
  @@index([userId, isPrimary])
  @@index([deletedAt])
}

model ChildWeaningRecord {
  id          String   @id @default(cuid())
  childId     String

  recordDate  DateTime @db.Date
  mealSlot    String
  foodNames   String
  amount      String   @default("normal")
  reaction    String   @default("ok")
  hasNewFood  Boolean  @default(false)
  note        String?

  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  child       Child    @relation(fields: [childId], references: [id], onDelete: Cascade)

  @@unique([childId, recordDate, mealSlot])
  @@index([childId])
  @@index([childId, recordDate])
  @@index([childId, createdAt])
  @@index([childId, reaction])
}

model ChildVaccinationRecord {
  id            String   @id @default(cuid())
  childId       String

  vaccineKey    String
  doseKey       String
  scheduledDate DateTime @db.Date
  completed     Boolean  @default(false)
  completedAt   DateTime? @db.Date
  note          String?

  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  child         Child    @relation(fields: [childId], references: [id], onDelete: Cascade)

  @@unique([childId, vaccineKey, doseKey])
  @@index([childId])
  @@index([childId, scheduledDate])
  @@index([childId, completed])
}


model ChildDevelopmentRecord {
  id          String   @id @default(cuid())
  childId     String

  ageRangeKey String
  domainKey   String
  itemKey     String
  status      String   @default("not_started")
  note        String?
  observedAt  DateTime? @db.Date

  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  child       Child    @relation(fields: [childId], references: [id], onDelete: Cascade)

  @@unique([childId, itemKey])
  @@index([childId])
  @@index([childId, ageRangeKey])
  @@index([childId, status])
}


model ChildDevelopmentCheckLog {
  id             String   @id @default(cuid())
  childId        String

  ageRangeKey    String
  domainKey      String
  itemKey        String
  previousStatus String?
  status         String
  note           String?
  observedAt     DateTime @db.Date

  createdAt      DateTime @default(now())

  child          Child    @relation(fields: [childId], references: [id], onDelete: Cascade)

  @@index([childId])
  @@index([childId, itemKey])
  @@index([childId, ageRangeKey])
  @@index([childId, createdAt])
}
